{
  "envFiles": {
    "primary": ".env.mcp.local",
    "fallback": ".env.local"
  },
  "credentialFiles": {
    "GA_SERVICE_ACCOUNT_JSON": {
      "path": "src/api/lib/cloud-credentials/google-analytics-data-api-service-account.json",
      "servers": ["google-analytics"],
      "required": false
    },
    "GOOGLE_APPLICATION_CREDENTIALS": {
      "path": "src/api/lib/cloud-credentials/search-console-credentials.json",
      "servers": ["gsc"],
      "required": false
    },
    "MERCHANT_CENTER_CREDENTIALS_PATH": {
      "path": "src/api/lib/cloud-credentials/merchant-center-credentials.json",
      "servers": ["merchant-data-mcp"],
      "required": false
    }
  },
  "requiredEnv": {
    "CONTEXT7_API_KEY": {
      "servers": ["context7", "upstash-context7"],
      "description": "Context7 MCP API key (ctx7sk-...)"
    }
  },
  "optionalEnv": {
    "FIRECRAWL_API_KEY": { "servers": ["firecrawl-mcp"] },
    "TRENDS_MCP_BEARER_TOKEN": { "servers": ["trends-mcp"] },
    "CLARITY_API_TOKEN": { "servers": ["@microsoft/clarity-mcp-server"] },
    "GOOGLE_DEVELOPER_KNOWLEDGE_API_KEY": { "servers": ["google-developer-knowledge"] },
    "GOOGLE_CLOUD_QUOTA_PROJECT": { "servers": ["google-developer-knowledge"] },
    "PAGESPEED_GOOGLE_API_KEY": { "servers": ["pagespeed"] },
    "GA_PROPERTY_ID": { "servers": ["google-analytics"] },
    "GA_MEASUREMENT_ID": { "servers": ["google-analytics"] },
    "GA_API_SECRET": { "servers": ["google-analytics"] },
    "GTM_CLIENT_ID": { "servers": ["gtm-mcp"] },
    "GTM_CLIENT_SECRET": { "servers": ["gtm-mcp"] },
    "GTM_PROJECT_ID": { "servers": ["gtm-mcp"] },
    "META_ACCESS_TOKEN": { "servers": ["meta-ads"] },
    "META_APP_ID": { "servers": ["meta-ads"] },
    "META_AUTO_REFRESH": { "servers": ["meta-ads"] },
    "META_BUSINESS_ID": { "servers": ["meta-ads"] }
  },
  "pathEnvDefaults": {
    "GA_SERVICE_ACCOUNT_JSON": "src/api/lib/cloud-credentials/google-analytics-data-api-service-account.json",
    "GOOGLE_APPLICATION_CREDENTIALS": "src/api/lib/cloud-credentials/search-console-credentials.json",
    "MERCHANT_CENTER_CREDENTIALS_PATH": "src/api/lib/cloud-credentials/merchant-center-credentials.json"
  }
}
