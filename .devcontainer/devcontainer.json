{
  "name": "utekos-headless",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/utekos-headless",
  "mounts": [
    "source=utekos-headless-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
  ],
  "forwardPorts": [3000, 54321, 54322, 54323, 54324, 54327, 12434],
  "portsAttributes": {
    "3000": {
      "label": "Next.js dev server"
    },
    "54321": {
      "label": "Supabase API"
    },
    "54322": {
      "label": "Supabase Postgres"
    },
    "54323": {
      "label": "Supabase Studio"
    },
    "54324": {
      "label": "Supabase Inbucket"
    },
    "54327": {
      "label": "Supabase Analytics"
    },
    "12434": {
      "label": "Docker Model Runner"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": false,
        "eslint.useFlatConfig": true,
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },
  "postCreateCommand": "sudo chown -R node:node node_modules && npm ci"
}
