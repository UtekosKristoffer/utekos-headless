# OpenAI Secure MCP Tunnel local runtime config.
# Copy to .env.tunnel.local and fill the two OpenAI values from Platform UI.

# Platform tunnel settings -> tunnel id.
CONTROL_PLANE_TUNNEL_ID=

# Runtime API key with Tunnels Read + Use for the tunnel.
CONTROL_PLANE_API_KEY=

# Local bearer token between tunnel-client and Docker MCP gateway.
# Generate a local value; do not reuse OpenAI/API provider keys here.
MCP_GATEWAY_AUTH_TOKEN=

# Default local profile/runtime. Target-specific npm scripts override these from
# config/mcp/chatgpt-profiles.json.
OPENAI_TUNNEL_PROFILE=utekos-docker-core
OPENAI_TUNNEL_MCP_COMMAND=docker mcp gateway run --profile utekos_core_safe
OPENAI_TUNNEL_MCP_PORT=8812
OPENAI_TUNNEL_HEALTH_ADDR=127.0.0.1:8080
DOCKER_MCP_PROFILE=utekos_core_safe

# Optional target-specific OpenAI values. Use these when each ChatGPT app has its
# own tunnel id or runtime key. If empty, the generic values above are used.
CONTROL_PLANE_TUNNEL_ID_INSIGHT=
CONTROL_PLANE_API_KEY_INSIGHT=
MCP_GATEWAY_AUTH_TOKEN_INSIGHT=
OPENAI_TUNNEL_PROFILE_INSIGHT=utekos-chatgpt-insight
DOCKER_MCP_PROFILE_INSIGHT=utekos_chatgpt_insight

CONTROL_PLANE_TUNNEL_ID_BROWSER=
CONTROL_PLANE_API_KEY_BROWSER=
MCP_GATEWAY_AUTH_TOKEN_BROWSER=
OPENAI_TUNNEL_PROFILE_BROWSER=utekos-chatgpt-browser
DOCKER_MCP_PROFILE_BROWSER=utekos_chatgpt_browser

CONTROL_PLANE_TUNNEL_ID_LIVE_OPS=
CONTROL_PLANE_API_KEY_LIVE_OPS=
MCP_GATEWAY_AUTH_TOKEN_LIVE_OPS=
OPENAI_TUNNEL_PROFILE_LIVE_OPS=utekos-chatgpt-live-ops
DOCKER_MCP_PROFILE_LIVE_OPS=utekos_chatgpt_live_ops

CONTROL_PLANE_TUNNEL_ID_COMMERCE_TRACKING=
CONTROL_PLANE_API_KEY_COMMERCE_TRACKING=
MCP_GATEWAY_AUTH_TOKEN_COMMERCE_TRACKING=
OPENAI_TUNNEL_PROFILE_COMMERCE_TRACKING=utekos-chatgpt-commerce-tracking
DOCKER_MCP_PROFILE_COMMERCE_TRACKING=utekos_chatgpt_commerce_tracking

# Optional legacy HTTP/proxy path. Prefer the stdio command above for ChatGPT tunnel use.
OPENAI_TUNNEL_PROXY_HOST=127.0.0.1
OPENAI_TUNNEL_PROXY_PORT=8813
OPENAI_TUNNEL_TARGET_ORIGIN=http://127.0.0.1:8812
